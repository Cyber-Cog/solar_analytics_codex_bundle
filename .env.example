# Solar Analytics — environment template. Copy to ".env" and edit.
#
#   cp .env.example .env
#
# These values are consumed by docker-compose.yml and the backend at runtime.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_DB=solar
POSTGRES_USER=solar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# ── Backend ─────────────────────────────────────────────────────────────────
# JWT signing key — MUST be rotated before going to production.
SECRET_KEY=change-me-in-production

# Gunicorn workers: (2 * CPU) + 1 is a reasonable default for prod.
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=180

# ── Web / reverse proxy ─────────────────────────────────────────────────────
# Public HTTP port. In dev, 8080 keeps it out of the way of other tools.
HTTP_PORT=8080

# ── Optional: override DATABASE_URL directly (e.g. point at AWS RDS) ────────
DATABASE_URL=postgresql://user:pass@rds.example.amazonaws.com:5432/solar
DATABASE_URL_READ=postgresql://user:pass@rds.example.amazonaws.com:5432/solar

# Optional: enable Vercel Blob for spec-sheet uploads when deploying to Vercel.
ENABLE_BLOB_UPLOADS=0
BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS=public

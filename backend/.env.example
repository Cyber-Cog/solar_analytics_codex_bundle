# REQUIRED: PostgreSQL connection (SQLite is no longer supported for the app).
# Example with Docker: docker compose up -d  then:
DATABASE_URL=postgresql://solar:solar@localhost:5432/solar
#
# For AWS RDS only: put your RDS URL in backend/.env on the server that runs this app.
# Schema (CREATE TABLE) is applied only to the database DATABASE_URL points at — not
# automatically to every Postgres on your machine. Keep localhost for other apps.
#
# Optional: after raw-data upload, background precompute fills module snapshot tables
# (ds_summary_snapshot, unified_fault_snapshot, loss_analysis_snapshot, unified_feed_category_totals). Set 0 to skip.
# SOLAR_MODULE_PRECOMPUTE=1
#
# Serverless / Vercel: avoid heavy on-request compute for fault unified feed, ds-summary,
# ds-scb-status, and loss /bridge.
# (503 if no snapshot, or return stale with _snapshot_meta if SOLAR_SNAPSHOT_ALLOW_STALE=1).
# Recommended production value: 1. Keep 0 only for local/dev repair runs.
# SOLAR_SNAPSHOT_READ_ONLY=1
# SOLAR_SNAPSHOT_ALLOW_STALE=1
#
# See backend/docs/PRECOMPUTE_OPERATIONS.md for ingest → precompute → worker scheduling.

# Postgres statement_timeout per connection (milliseconds). If you see
# "canceling statement due to statement timeout" on large plants, do not raise this
# on Vercel above the function maxDuration; precompute snapshots instead.
# Defaults: serverless 25000, non-serverless 300000.
# DB_STATEMENT_TIMEOUT_MS=25000

# Serverless (VERCEL=1 or SOLAR_SERVERLESS=1) only: SQLAlchemy QueuePool on each engine.
# Raise max_overflow (and rarely pool_size) if parallel dashboard bundle workers wait on
# the pool; ensure Postgres max_connections can absorb concurrent serverless invocations.
# DB_SERVERLESS_POOL_SIZE=1
# DB_SERVERLESS_MAX_OVERFLOW=2
# DB_SERVERLESS_POOL_TIMEOUT=10

# Optional: shared response cache for dashboard/routers (strongly recommended on serverless
# so repeat requests hit Redis instead of cold in-process). Example:
# REDIS_URL=redis://localhost:6379/0

# Optional: log SQL queries (1 or true)
# SQL_ECHO=0

# Optional: power limitation — drop from reference (0.30 = flag when actual < 70% of median peer AC)
# PL_DROP_FROM_REFERENCE=0.30

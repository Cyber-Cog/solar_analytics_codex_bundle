# REQUIRED: PostgreSQL connection (SQLite is no longer supported for the app).
# Example with Docker: docker compose up -d  then:
DATABASE_URL=postgresql://solar:solar@localhost:5432/solar
#
# For AWS RDS only: put your RDS URL in backend/.env on the server that runs this app.
# Schema (CREATE TABLE) is applied only to the database DATABASE_URL points at — not
# automatically to every Postgres on your machine. Keep localhost for other apps.
#
# Optional: after raw-data upload, background precompute fills module snapshot tables
# (ds_summary_snapshot, unified_fault_snapshot, loss_analysis_snapshot). Set 0 to skip.
# SOLAR_MODULE_PRECOMPUTE=1

# Postgres statement_timeout per connection (milliseconds). If you see
# "canceling statement due to statement timeout" on large plants, set higher (e.g. 600000)
# or ensure indexes in db_perf / migrations ran. Default when not serverless: 300000 (5 min).
# DB_STATEMENT_TIMEOUT_MS=300000

# Optional: log SQL queries (1 or true)
# SQL_ECHO=0

# Optional: power limitation — drop from reference (0.30 = flag when actual < 70% of median peer AC)
# PL_DROP_FROM_REFERENCE=0.30
